# Experimental Codex execpolicy rules for presentation/testing.

prefix_rule(
    pattern = ["rm", "-rf", "src/__pycache__"],
    decision = "allow",
    justification = "Allow removing generated Python cache directories under this repo.",
    match = [
        "rm -rf src/__pycache__",
    ],
    not_match = [
        "rm -rf .",
        "rm -rf src",
    ],
)

prefix_rule(
    pattern = ["rm", "-rf", "test/__pycache__"],
    decision = "allow",
    justification = "Allow removing generated Python cache directories under this repo.",
    match = [
        "rm -rf test/__pycache__",
    ],
    not_match = [
        "rm -rf .",
        "rm -rf test",
    ],
)

prefix_rule(
    pattern = ["rm", "-rf", "src"],
    decision = "prompt",
    justification = "Prompt before recursively removing this demo folder.",
    match = [
        "rm -rf src",
    ],
    not_match = [
        "rm -rf src/__pycache__",
        "rm -rf .",
    ],
)

prefix_rule(
    pattern = ["rm", "-rf", "."],
    decision = "forbidden",
    justification = "Never remove the current working directory; confirm with the user again for what to delete.",
    match = [
        "rm -rf .",
    ],
    not_match = [
        "rm -rf ./tmp",
        "rm -rf src/__pycache__",
    ],
)
