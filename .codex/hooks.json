{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 .codex/hooks/log_conversation.py --event UserPromptSubmit",
            "timeout": 30,
            "statusMessage": "Logging submitted user prompt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 .codex/hooks/log_conversation.py --event Stop",
            "timeout": 30,
            "statusMessage": "Logging stop hook payload"
          }
        ]
      }
    ]
  }
}
